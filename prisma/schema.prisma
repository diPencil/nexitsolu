generator client {
  provider        = "prisma-client-js"
}

// Prisma 7: put the DB URL in `prisma.config.ts` only — `url` here is invalid for the CLI (P1012).
// If the editor still flags “url is missing”, reload the window; workspace has `prisma.enableDiagnostics: false` in `.vscode/settings.json` for that false positive.
datasource db {
  provider = "mysql"
}

model User {
  id                String             @id @default(cuid())
  name              String?
  email             String             @unique
  password          String
  role              Role               @default(CUSTOMER)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  governorate       String?
  phone             String?
  username          String?            @unique
  position          String?
  whatsapp          String?
  isSupportClosed   Boolean            @default(false)
  closedReason      String?
  status            String             @default("ACTIVE") // ACTIVE, BLOCKED
  favorites         Favorite[]
  managedITRequests ManagedITRequest[]
  conversations     Conversation[]
  messagesRecv      Message[]          @relation("ReceivedMessages")
  messagesSent      Message[]          @relation("SentMessages")
  notifications     Notification[]
  orders            Order[]
  reviews           Review[]
  subscriptions     Subscription[]
  wishlist          Wishlist[]
  invoices          Invoice[]
  quotations        Quotation[]
  quotationRequests QuotationRequest[]
  activityLogs      ActivityLog[]
  internalExpenses  InternalExpense[]
}

model ActivityLog {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  userId       String?
  userEmail    String?
  userRole     String?
  username     String?
  action       String
  category     String
  summary      String
  path         String?
  method       String?
  resourceType String?
  resourceId   String?
  metadata     Json?
  ip           String?
  userAgent    String?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId])
  @@index([category])
  @@index([action])
}

model Product {
  id            String      @id @default(cuid())
  name          String
  nameAr        String?
  description       String?     @db.Text
  descriptionAr     String?     @db.Text
  longDescription   String?     @db.LongText
  longDescriptionAr String?     @db.LongText
  price         Float
  discountPrice Float?
  category      String
  image         String?
  gallery       String?
  tag           String?
  stock         Int         @default(0)
  shippingZones String?
  views         Int         @default(0)
  shares        Int         @default(0)
  active        Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  favoritedBy   Favorite[]
  orderItems    OrderItem[]
  reviews       Review[]
  wishlistedBy  Wishlist[]
  purchases     Purchase[]
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  total           Float
  status          OrderStatus @default(PENDING)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  notes           String?       @db.Text
  orderNumber     String?       @unique
  paidAmount      Float?
  paymentMethod   String?
  paymentType     String?
  shippingAddress String?       @db.Text
  shippingCity    String?
  shippingName    String?
  shippingPhone   String?
  senderPhone     String?
  transactionId   String?
  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]
  invoices        Invoice[]
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model ShippingZone {
  id       String  @id @default(cuid())
  name     String  @unique
  nameAr   String
  nameEn   String
  price    Float
  isActive Boolean @default(true)
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  product   Product @relation(fields: [productId], references: [id])
  order     Order   @relation(fields: [orderId], references: [id])
}

model Category {
  id      String  @id @default(cuid())
  name    String  @unique // unique slug like "workstations"
  nameAr  String
  nameEn  String
  createdAt DateTime @default(now())
}

model Conversation {
  id              String    @id @default(cuid())
  ticketId        String    @unique // e.g., NEX-1001
  userId          String
  status          String    @default("OPEN") // OPEN, CLOSED
  closedReason    String?
  closedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id])
  messages        Message[]
}

model Message {
  id             String       @id @default(cuid())
  senderId       String
  receiverId     String
  conversationId String?
  content        String         @db.LongText
  createdAt      DateTime     @default(now())
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  receiver       User         @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
}

model Subscription {
  id         String   @id @default(cuid())
  userId     String
  planName   String
  /** Matches SubscriptionService.key */
  serviceKey String?
  amount     Float
  type       String
  status     String   @default("ACTIVE")
  startDate  DateTime @default(now())
  endDate    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])
}

/** Admin-defined services used when creating subscriptions (NexIT lines + custom). */
model SubscriptionService {
  id        String   @id @default(cuid())
  key       String   @unique
  nameEn    String
  nameAr    String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/** Admin-defined plan tiers (Bronze, Gold, …); optional link to one service or all. */
model SubscriptionPlan {
  id              String   @id @default(cuid())
  /** If null, plan appears for every service; else only when that service is selected. */
  serviceKey      String?
  nameEn          String
  nameAr          String
  suggestedAmount Float?
  sortOrder       Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ManagedITRequest {
  id          String   @id @default(cuid())
  userId      String
  companyName String
  industry    String?
  services    String
  model       String
  days        String
  hours       String
  contactName String
  email       String
  phone       String
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  productId String
  rating    Int      @default(5)
  comment   String              @db.Text
  reply           String?       @db.Text
  customerReply   String?       @db.Text
  customerReplyAt DateTime?
  status          String   @default("APPROVED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  ReviewMessage[]
  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model ReviewMessage {
  id        String   @id @default(cuid())
  reviewId  String
  userId    String
  content   String
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

enum Role {
  ADMIN
  CUSTOMER
  COMPANY
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String              @db.LongText
  status    String   @default("UNREAD") // UNREAD, READ, REPLIED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TechSupportRequest {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  whatsapp    String?
  supportType String
  message     String            @db.LongText
  status      String   @default("PENDING") // PENDING, IN_PROGRESS, RESOLVED, CLOSED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Invoice {
  id          String   @id @default(cuid())
  invoiceNo   String   @unique
  userId      String
  orderId     String?
  amount      Float
  status      String   @default("PENDING") // PENDING, PAID, CANCELLED
  fileUrl     String?
  dueDate     DateTime?
  notes       String?           @db.Text
  items       Json?
  subtotal    Float?
  discount    Float?
  tax         Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
  order       Order?   @relation(fields: [orderId], references: [id])
}

model Quotation {
  id          String   @id @default(cuid())
  quotationNo String   @unique
  userId      String
  amount      Float
  status      String   @default("PENDING") // PENDING, SENT, APPROVED, REJECTED, EXPIRED
  notes       String?           @db.Text
  items       Json?
  subtotal    Float?
  discount    Float?
  tax         Float?
  validUntil  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model QuotationRequest {
  id          String   @id @default(cuid())
  userId      String?
  name        String
  email       String
  phone       String?
  company     String?
  service     String?
  message     String            @db.LongText
  status      String   @default("PENDING") // PENDING, REVIEWED, QUOTED, CLOSED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id])
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  contact   String?
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  purchases Purchase[]
}

model Purchase {
  id           String   @id @default(cuid())
  supplierId   String
  productId    String
  quantity     Int
  unitPrice    Float
  totalPrice   Float
  status       String   @default("COMPLETED") // PENDING, COMPLETED, CANCELLED
  purchaseDate DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  paymentStatus   String  @default("UNPAID") // PAID | UNPAID
  paymentMethod   String? // INSTAPAY, WALLET, CASH, BANK_TRANSFER
  transactionRef  String?
  amountPaid      Float   @default(0)
  amountRemaining Float   @default(0) // snapshot: totalPrice - amountPaid at save

  supplier     Supplier @relation(fields: [supplierId], references: [id])
  product      Product  @relation(fields: [productId], references: [id])
}

/// Operational / shared costs (warehouse, transport, etc.) — not tied to suppliers or stock.
model InternalExpense {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  spentAt     DateTime @default(now())
  category    String?
  notes       String?           @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([spentAt])
}

