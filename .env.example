# Copy to ".env" or ".env.local" and fill in values. Never commit real secrets.

# SQLite (LibSQL) — path is relative to project root unless you use a full file: URL
DATABASE_URL="file:./prisma/dev.db"

# Set to 1 to skip automatic prisma db push when the Node server starts (production + file: URLs only)
# SKIP_RUNTIME_PRISMA_DB_PUSH=

# Production: if the database has zero users, create one ADMIN at server start (Hostinger / fresh SQLite)
# BOOTSTRAP_ADMIN_EMAIL=admin@nexitsolu.com
# BOOTSTRAP_ADMIN_USERNAME=admin
# BOOTSTRAP_ADMIN_PASSWORD=change-me-immediately
# SKIP_AUTO_ADMIN_BOOTSTRAP=1

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-long-random-string"

# Random secret so Edge middleware can POST audit rows to /api/internal/activity (e.g. openssl rand -hex 32)
# ACTIVITY_LOG_INTERNAL_SECRET=

# Optional: Pusher (defaults exist in code for dev)
# PUSHER_APP_ID=
# PUSHER_KEY=
# PUSHER_SECRET=
# PUSHER_CLUSTER=mt1
# NEXT_PUBLIC_PUSHER_KEY=
# NEXT_PUBLIC_PUSHER_CLUSTER=mt1

# Optional: Google AI
# GOOGLE_GENERATIVE_AI_API_KEY=
